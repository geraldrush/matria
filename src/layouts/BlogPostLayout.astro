---
import MainLayout from '../../layouts/MainLayout.astro';

export interface Props {
  title: string;
  date: string;
  author: string;
  image: string;
  category: string;
  slug: string;
  description: string;
}

const { title, date, author, image, category, slug, description } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-ZA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<MainLayout title={`${title} | Matria Blog`} description={description}>
    <article class="blog-post">
        <section class="post-hero">
            <div class="container">
                <div class="post-meta">
                    <span class="post-category">{category}</span>
                    <time datetime={date}>{formattedDate}</time>
                    <span>By {author}</span>
                </div>
                <h1>{title}</h1>
            </div>
        </section>

        <div class="post-image-wrapper">
            <img src={image} alt={title} class="post-image" loading="lazy" />
        </div>

        <div class="post-content">
            <div class="container">
                <div class="post-body">
                    <slot />
                </div>

                <aside class="post-sidebar">
                    <div class="sidebar-card">
                        <h3>About Matria</h3>
                        <p>Expert plumbing and electrical services across Pretoria and Johannesburg. Available 24/7 for emergencies with professional, licensed technicians.</p>
                        <a href="/about/" class="btn btn-primary">Learn More</a>
                    </div>

                    <div class="sidebar-card">
                        <h3>Need Service?</h3>
                        <p><strong>Call:</strong> <a href="tel:+27737616835">+27 73 761 6835</a></p>
                        <p><strong>Email:</strong> <a href="mailto:plumber@matria.co.za">plumber@matria.co.za</a></p>
                        <p><strong>Available:</strong> 24/7</p>
                        <a href="/contact/" class="btn btn-primary">Request Service</a>
                    </div>

                    <div class="sidebar-card">
                        <h3>Read More</h3>
                        <a href="/blog/">← Back to Blog</a>
                    </div>
                </aside>
            </div>
        </div>

        <section class="cta-section">
            <div class="container cta-content">
                <h2>Have a Plumbing or Electrical Issue?</h2>
                <p>Contact our expert team for professional service</p>
                <div class="cta-buttons">
                    <a href="/contact/" class="btn btn-primary btn-large">Get Help Now</a>
                    <a href="tel:+27737616835" class="btn btn-secondary btn-large">+27 73 761 6835</a>
                </div>
            </div>
        </section>
    </article>
</MainLayout>

<style>
    .post-hero {
        background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 100%);
        color: white;
        padding: 60px 20px 40px;
    }

    .post-meta {
        display: flex;
        gap: 20px;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        opacity: 0.95;
    }

    .post-category {
        background: rgba(255, 255, 255, 0.3);
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
    }

    .post-meta time {
        display: block;
    }

    .post-hero h1 {
        color: white;
        font-size: 2.5rem;
        margin-bottom: 0;
    }

    .post-image-wrapper {
        width: 100%;
        height: 400px;
        overflow: hidden;
    }

    .post-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .post-content {
        padding: 60px 20px;
    }

    .post-body {
        max-width: 700px;
        margin: 0 auto 40px;
    }

    .post-body :global(h2) {
        margin-top: 2rem;
        margin-bottom: 1rem;
        color: var(--primary-green);
    }

    .post-body :global(h3) {
        margin-top: 1.5rem;
        margin-bottom: 0.8rem;
    }

    .post-body :global(p) {
        margin-bottom: 1.2rem;
        line-height: 1.8;
        color: #666;
    }

    .post-body :global(ul),
    .post-body :global(ol) {
        margin-bottom: 1.5rem;
        padding-left: 30px;
    }

    .post-body :global(li) {
        margin-bottom: 0.6rem;
        color: #666;
        line-height: 1.6;
    }

    .post-body :global(blockquote) {
        border-left: 4px solid var(--primary-green);
        padding-left: 20px;
        margin: 2rem 0;
        color: #666;
        font-style: italic;
    }

    .post-sidebar {
        max-width: 700px;
        margin-left: auto;
    }

    .sidebar-card {
        background: var(--bg-light);
        padding: 25px;
        border-radius: 12px;
        margin-bottom: 20px;
        border-left: 4px solid var(--primary-green);
    }

    .sidebar-card h3 {
        color: var(--primary-green);
        margin-bottom: 1rem;
    }

    .sidebar-card a {
        color: var(--primary-green);
        font-weight: 600;
    }

    .sidebar-card p {
        margin-bottom: 0.8rem;
    }

    .cta-section {
        background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 100%);
        color: white;
        padding: 60px 20px;
    }

    .cta-content {
        text-align: center;
    }

    .cta-content h2 {
        color: white;
        margin-bottom: 1rem;
    }

    .cta-content p {
        color: rgba(255, 255, 255, 0.95);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    @media (max-width: 768px) {
        .post-hero h1 {
            font-size: 1.8rem;
        }

        .post-image-wrapper {
            height: 250px;
        }

        .post-content {
            padding: 40px 20px;
        }

        .cta-buttons {
            flex-direction: column;
        }
    }
</style>
