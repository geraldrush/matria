---
// Google Reviews Widget - Links to Google Business profile
---

<section class="reviews-section">
    <div class="container">
        <h2 class="text-center">What Our Customers Say</h2>
        <p class="text-center section-subtitle">Join hundreds of satisfied customers across Pretoria and Johannesburg</p>
        
        <div class="reviews-container">
            <div class="review-card">
                <div class="stars">★★★★★</div>
                <p>"Excellent service! They arrived on time and fixed our emergency leak quickly. Highly recommended!"</p>
                <strong>- John M., Pretoria</strong>
            </div>
            
            <div class="review-card">
                <div class="stars">★★★★★</div>
                <p>"Professional team, great workmanship. The electrical installation was done perfectly."</p>
                <strong>- Sarah L., Johannesburg</strong>
            </div>
            
            <div class="review-card">
                <div class="stars">★★★★★</div>
                <p>"Best plumbers in Joburg! Quick response, fair pricing, and they clean up after themselves."</p>
                <strong>- David T., Johannesburg</strong>
            </div>
            
            <div class="review-card">
                <div class="stars">★★★★★</div>
                <p>"Available 24/7 and they really mean it! Called at midnight with an emergency and they responded."</p>
                <strong>- Patricia K., Pretoria</strong>
            </div>
        </div>
        
        <div class="text-center mt-4">
            <a href="https://www.google.com/search?q=Matria+Plumbing+Electrical+Services" target="_blank" class="btn btn-primary">
                View All Reviews on Google
            </a>
            <a href="https://www.google.com/maps/search/Matria+Plumbing+Electrical" target="_blank" class="btn btn-outline ml-2">
                Leave a Review
            </a>
        </div>
    </div>
</section>

<style>
    .reviews-section {
        background-color: var(--bg-light);
        padding: 80px 20px;
    }

    .reviews-section h2 {
        margin-bottom: 0.5rem;
    }

    .section-subtitle {
        font-size: 1.1rem;
        color: #999;
        margin-bottom: 3rem;
    }

    .reviews-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        margin-bottom: 3rem;
    }

    .review-card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: var(--shadow);
        border-left: 4px solid var(--primary-green);
    }

    .review-card .stars {
        color: #ffc107;
        font-size: 1.3rem;
        margin-bottom: 1rem;
        letter-spacing: 2px;
    }

    .review-card p {
        color: #666;
        margin-bottom: 1.5rem;
        font-style: italic;
    }

    .review-card strong {
        color: var(--accent-dark);
        display: block;
    }

    .ml-2 {
        margin-left: 1rem;
    }

    @media (max-width: 768px) {
        .reviews-section {
            padding: 60px 20px;
        }

        .reviews-container {
            grid-template-columns: 1fr;
        }

        .ml-2 {
            margin-left: 0;
            margin-top: 1rem;
            display: block;
        }
    }
</style>
