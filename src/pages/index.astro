---
import MainLayout from '../layouts/MainLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ReviewsWidget from '../components/ReviewsWidget.astro';
---

<MainLayout title="Matria Plumbing & Electrical Services | Pretoria & Johannesburg" description="Premium plumbing and electrical services in Pretoria and Johannesburg. 24/7 emergency repairs, installations, and maintenance. Call +27 73 761 6835">
    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Professional Plumbing & Electrical Services</h1>
            <p>Trusted by hundreds of customers across Pretoria and Johannesburg</p>
            <div class="hero-buttons">
                <a href="/contact/" class="btn btn-primary btn-large">Get Emergency Service</a>
                <a href="/services/" class="btn btn-outline btn-large">Explore Services</a>
            </div>
            <div class="hero-stats">
                <div class="stat">
                    <strong>24/7</strong>
                    <span>Emergency Service</span>
                </div>
                <div class="stat">
                    <strong>500+</strong>
                    <span>Happy Customers</span>
                </div>
                <div class="stat">
                    <strong>15+</strong>
                    <span>Years Experience</span>
                </div>
            </div>
        </div>
        <img src="https://images.unsplash.com/photo-1581464492846-61b1ef2ff297?w=800&h=600&fit=crop" alt="Professional plumber at work" class="hero-image" loading="lazy" />
    </section>

    <!-- Quick Services -->
    <section class="quick-services">
        <div class="container">
            <h2 class="text-center">Why Choose Matria?</h2>
            <div class="features-grid">
                <div class="feature">
                    <span class="feature-icon">⚡</span>
                    <h3>Fast Response</h3>
                    <p>Same-day service in most cases. Call us 24/7 for emergencies.</p>
                </div>
                <div class="feature">
                    <span class="feature-icon">👨‍🔧</span>
                    <h3>Expert Team</h3>
                    <p>Licensed and experienced plumbers and electricians with proven track record.</p>
                </div>
                <div class="feature">
                    <span class="feature-icon">💰</span>
                    <h3>Fair Pricing</h3>
                    <p>Transparent quotes with no hidden charges. Competitive rates guaranteed.</p>
                </div>
                <div class="feature">
                    <span class="feature-icon">✓</span>
                    <h3>Guaranteed Work</h3>
                    <p>100% satisfaction guarantee. All work is guaranteed for 12 months.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Services -->
    <section class="featured-services bg-light">
        <div class="container">
            <h2 class="text-center">Our Services</h2>
            <p class="text-center section-subtitle">From emergency repairs to complete installations</p>
            <div class="services-grid">
                <ServiceCard 
                    title="Emergency Plumbing"
                    description="24/7 emergency response for burst pipes, leaks, and urgent repairs. Our team handles any plumbing emergency."
                    icon="💧"
                    image="https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=500&h=400&fit=crop"
                />
                <ServiceCard 
                    title="Electrical Services"
                    description="Expert electrical installation, repair, and maintenance. Safe and reliable electrical solutions for your home or business."
                    icon="⚡"
                    image="https://images.unsplash.com/photo-1621905167918-48416bd8575a?w=500&h=400&fit=crop"
                />
                <ServiceCard 
                    title="Maintenance Plans"
                    description="Preventative maintenance packages to keep your systems running smoothly and avoid costly repairs later."
                    icon="🔧"
                    image="https://images.unsplash.com/photo-1596905030625-6f6de0e0fda9?w=500&h=400&fit=crop"
                />
            </div>
            <div class="text-center mt-4">
                <a href="/services/" class="btn btn-primary">View All Services</a>
            </div>
        </div>
    </section>

    <!-- Reviews Section -->
    <ReviewsWidget />

    <!-- Service Areas -->
    <section class="service-areas">
        <div class="container">
            <h2 class="text-center">We Serve You</h2>
            <p class="text-center section-subtitle">Operating in Pretoria and Johannesburg with mobile service</p>
            <div class="areas-grid">
                <div class="area-card">
                    <h3>📍 Pretoria</h3>
                    <p>Complete coverage across Pretoria with quick response times. We handle residential and commercial properties.</p>
                    <a href="/contact/?area=pretoria" class="btn btn-outline">Book Service</a>
                </div>
                <div class="area-card">
                    <h3>📍 Johannesburg</h3>
                    <p>Serving all areas of Johannesburg with professional and reliable service. Same-day appointments available.</p>
                    <a href="/contact/?area=johannesburg" class="btn btn-outline">Book Service</a>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container cta-content">
            <h2>Need Immediate Assistance?</h2>
            <p>Contact us now for emergency plumbing and electrical services available 24/7</p>
            <div class="cta-buttons">
                <a href="tel:+27737616835" class="btn btn-primary btn-large">📞 Call Now: +27 73 761 6835</a>
                <a href="mailto:plumber@matria.co.za" class="btn btn-secondary btn-large">✉️ Email Us</a>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .hero {
        background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 100%);
        color: white;
        padding: 100px 20px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 50px;
        align-items: center;
    }

    .hero-content h1 {
        color: white;
        font-size: 3.5rem;
        margin-bottom: 1rem;
    }

    .hero-content > p {
        font-size: 1.3rem;
        margin-bottom: 2rem;
        color: rgba(255, 255, 255, 0.95);
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
        margin-bottom: 3rem;
    }

    .btn-large {
        padding: 15px 35px;
        font-size: 1.1rem;
    }

    .hero-stats {
        display: flex;
        gap: 40px;
    }

    .stat {
        display: flex;
        flex-direction: column;
    }

    .stat strong {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.5rem;
    }

    .stat span {
        font-size: 0.9rem;
        opacity: 0.95;
    }

    .hero-image {
        width: 100%;
        height: 500px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    }

    .quick-services {
        padding: 80px 20px;
    }

    .quick-services h2 {
        margin-bottom: 3rem;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 40px;
        margin-bottom: 3rem;
    }

    .feature {
        text-align: center;
    }

    .feature-icon {
        font-size: 3rem;
        display: block;
        margin-bottom: 1rem;
    }

    .feature h3 {
        color: var(--primary-green);
        margin-bottom: 1rem;
    }

    .feature p {
        color: #666;
    }

    .featured-services {
        padding: 80px 20px;
    }

    .featured-services h2 {
        margin-bottom: 0.5rem;
    }

    .section-subtitle {
        font-size: 1.1rem;
        color: #999;
        margin-bottom: 3rem;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin-bottom: 2rem;
    }

    .bg-light {
        background-color: var(--bg-light);
    }

    .service-areas {
        padding: 80px 20px;
    }

    .service-areas h2 {
        margin-bottom: 0.5rem;
    }

    .areas-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin-top: 3rem;
    }

    .area-card {
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: var(--shadow);
        text-align: center;
        border-top: 4px solid var(--primary-green);
    }

    .area-card h3 {
        margin-bottom: 1rem;
    }

    .area-card p {
        color: #666;
        margin-bottom: 2rem;
    }

    .cta-section {
        background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 100%);
        color: white;
        padding: 60px 20px;
    }

    .cta-content {
        text-align: center;
    }

    .cta-content h2 {
        color: white;
        margin-bottom: 1rem;
    }

    .cta-content p {
        color: rgba(255, 255, 255, 0.95);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    @media (max-width: 768px) {
        .hero {
            grid-template-columns: 1fr;
            padding: 60px 20px;
        }

        .hero-content h1 {
            font-size: 2rem;
        }

        .hero-buttons {
            flex-direction: column;
        }

        .hero-stats {
            flex-direction: column;
            gap: 20px;
        }

        .hero-image {
            height: 300px;
        }

        .cta-buttons {
            flex-direction: column;
        }
    }
</style>
