---
import MainLayout from "../layouts/MainLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ReviewsWidget from "../components/ReviewsWidget.astro";
import Icon from "../components/Icon.astro";
---

<MainLayout
  title="Matria Plumbing & Electrical Services | Pretoria & Johannesburg"
  description="Premium plumbing and electrical services in Pretoria and Johannesburg. 24/7 emergency repairs, installations, and maintenance. Call +27 73 761 6835"
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>Professional Plumbing & Electrical Services</h1>
      <p>Trusted by hundreds of customers across Pretoria and Johannesburg</p>
      <div class="hero-buttons">
        <a href="/contact/" class="btn btn-primary btn-large">
          <Icon name="phone" size={20} />
          Get Emergency Service
        </a>
        <a href="/services/" class="btn btn-outline btn-large"
          >Explore Services</a
        >
      </div>
    </div>
    <div class="hero-image-wrapper">
      <img
        src="https://images.unsplash.com/photo-1607472586893-edb57bdc0e39?w=800&h=600&fit=crop"
        alt="Professional plumber fixing pipes"
        class="hero-image"
        loading="eager"
      />
    </div>
  </section>

  <!-- Quick Services -->
  <section class="quick-services">
    <div class="container">
      <h2 class="text-center">Why Choose Matria?</h2>
      <div class="features-grid">
        <div class="feature">
          <div class="feature-icon">
            <Icon name="bolt" size={40} />
          </div>
          <h3>Fast Response</h3>
          <p>Same-day service in most cases. Call us 24/7 for emergencies.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <Icon name="shield" size={40} />
          </div>
          <h3>Expert Team</h3>
          <p>
            Licensed and experienced plumbers and electricians with proven track
            record.
          </p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <Icon name="check" size={40} />
          </div>
          <h3>Fair Pricing</h3>
          <p>
            Transparent quotes with no hidden charges. Competitive rates
            guaranteed.
          </p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <Icon name="star" size={40} />
          </div>
          <h3>Guaranteed Work</h3>
          <p>
            100% satisfaction guarantee. All work is guaranteed for 12 months.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Services -->
  <section class="featured-services bg-light">
    <div class="container">
      <h2 class="text-center">Our Services</h2>
      <p class="text-center section-subtitle">
        From emergency repairs to complete installations
      </p>
      <div class="services-grid">
        <ServiceCard
          title="Emergency Plumbing"
          description="24/7 emergency response for burst pipes, leaks, and urgent repairs. Our team handles any plumbing emergency."
          icon="droplet"
          image="https://images.unsplash.com/photo-1607472586893-edb57bdc0e39?w=500&h=400&fit=crop"
        />
        <ServiceCard
          title="Electrical Services"
          description="Expert electrical installation, repair, and maintenance. Safe and reliable electrical solutions for your home or business."
          icon="bolt"
          image="https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=500&h=400&fit=crop"
        />
        <ServiceCard
          title="Maintenance Plans"
          description="Preventative maintenance packages to keep your systems running smoothly and avoid costly repairs later."
          icon="tools"
          image="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=500&h=400&fit=crop"
        />
      </div>
      <div class="text-center mt-4">
        <a href="/services/" class="btn btn-primary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <ReviewsWidget />

  <!-- Service Areas -->
  <section class="service-areas">
    <div class="container">
      <h2 class="text-center">We Serve You</h2>
      <p class="text-center section-subtitle">
        Operating in Pretoria and Johannesburg with mobile service
      </p>
      <div class="areas-grid">
        <div class="area-card">
          <Icon name="location" size={48} />
          <h3>Pretoria</h3>
          <p>
            Complete coverage across Pretoria with quick response times. We
            handle residential and commercial properties.
          </p>
          <a href="/contact/?area=pretoria" class="btn btn-outline"
            >Book Service</a
          >
        </div>
        <div class="area-card">
          <Icon name="location" size={48} />
          <h3>Johannesburg</h3>
          <p>
            Serving all areas of Johannesburg with professional and reliable
            service. Same-day appointments available.
          </p>
          <a href="/contact/?area=johannesburg" class="btn btn-outline"
            >Book Service</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container cta-content">
      <h2>Need Immediate Assistance?</h2>
      <p>
        Contact us now for emergency plumbing and electrical services available
        24/7
      </p>
      <div class="cta-buttons">
        <a href="tel:+27737616835" class="btn btn-primary btn-large">
          <Icon name="phone" size={20} />
          Call Now: +27 73 761 6835
        </a>
        <a
          href="mailto:plumber@matria.co.za"
          class="btn btn-secondary btn-large"
        >
          <Icon name="email" size={20} />
          Email Us
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Mobile-first approach */
  .hero {
    background: linear-gradient(
      135deg,
      var(--primary-green) 0%,
      var(--primary-green-light) 100%
    );
    color: white;
    padding: 3rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-content h1 {
    color: white;
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .hero-content > p {
    font-size: 1.125rem;
    margin-bottom: 2rem;
    color: rgba(255, 255, 255, 0.95);
  }

  .hero-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .btn-large {
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
  }

  .stat strong {
    font-size: 1.75rem;
    font-weight: 800;
    display: block;
  }

  .stat span {
    font-size: 0.875rem;
    opacity: 0.95;
  }

  .hero-image-wrapper {
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  .hero-image {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
  }

  .quick-services {
    padding: 3rem 1.25rem;
  }

  .quick-services h2 {
    margin-bottom: 2.5rem;
    font-size: 2rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 1.5rem;
  }

  .feature-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1rem;
    background: linear-gradient(
      135deg,
      var(--primary-green-lightest),
      var(--primary-green-lighter)
    );
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-green);
  }

  .feature h3 {
    color: var(--primary-green);
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .feature p {
    color: #666;
    font-size: 0.9375rem;
  }

  .featured-services {
    padding: 3rem 1.25rem;
  }

  .featured-services h2 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
  }

  .section-subtitle {
    font-size: 1rem;
    color: #999;
    margin-bottom: 2.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .service-areas {
    padding: 3rem 1.25rem;
  }

  .service-areas h2 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
  }

  .areas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .area-card {
    background: white;
    padding: 2rem;
    border-radius: 1rem;
    box-shadow: var(--shadow);
    text-align: center;
    border-top: 4px solid var(--primary-green);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .area-card h3 {
    margin: 0;
    font-size: 1.5rem;
  }

  .area-card p {
    color: #666;
    margin: 0;
  }

  .cta-section {
    background: linear-gradient(
      135deg,
      var(--primary-green) 0%,
      var(--primary-green-light) 100%
    );
    color: white;
    padding: 3rem 1.25rem;
  }

  .cta-content {
    text-align: center;
  }

  .cta-content h2 {
    color: white;
    margin-bottom: 1rem;
    font-size: 1.75rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.95);
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  /* Tablet and up */
  @media (min-width: 768px) {
    .hero {
      padding: 4rem 2rem;
    }

    .hero-content h1 {
      font-size: 2.5rem;
    }

    .hero-buttons {
      flex-direction: row;
    }

    .hero-image {
      height: 400px;
    }

    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .areas-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .cta-buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .hero {
      padding: 5rem 2rem;
      flex-direction: row;
      align-items: center;
      gap: 4rem;
    }

    .hero-content {
      flex: 1;
    }

    .hero-image-wrapper {
      flex: 1;
    }

    .hero-content h1 {
      font-size: 3.5rem;
    }

    .hero-content > p {
      font-size: 1.25rem;
    }

    .hero-stats {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .stat {
      align-items: flex-start;
      text-align: left;
    }

    .stat strong {
      font-size: 2.5rem;
    }

    .hero-image {
      height: 500px;
    }

    .quick-services,
    .featured-services,
    .service-areas {
      padding: 5rem 2rem;
    }

    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .cta-section {
      padding: 4rem 2rem;
    }

    .cta-content h2 {
      font-size: 2.5rem;
    }

    .cta-content p {
      font-size: 1.125rem;
    }
  }
</style>
