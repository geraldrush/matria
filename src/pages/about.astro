---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="About Matria | Plumbing & Electrical Services" description="Learn about Matria's team of expert plumbers and electricians serving Pretoria and Johannesburg with professional, reliable service.">
    <section class="page-hero">
        <div class="container">
            <h1>About Matria</h1>
            <p>Your trusted partner for professional plumbing and electrical services</p>
        </div>
    </section>

    <section class="about-section">
        <div class="container">
            <div class="about-grid">
                <div class="about-content">
                    <h2>Who We Are</h2>
                    <p>Matria Plumbing & Electrical Services is a dedicated team of licensed professionals committed to providing top-quality plumbing and electrical solutions across Pretoria and Johannesburg.</p>
                    <p>With over 15 years of combined experience, we've built our reputation on reliability, expertise, and customer satisfaction. We understand that plumbing and electrical emergencies can't wait, which is why we're available 24/7 to serve you.</p>
                    <p>Our team consists of SABS-compliant, fully licensed plumbers and electricians who approach every job with professionalism and attention to detail.</p>
                </div>
                <div class="about-image">
                    <img src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=500&h=400&fit=crop" alt="Our professional team" loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <section class="values-section bg-light">
        <div class="container">
            <h2 class="text-center mb-4">Our Values</h2>
            <div class="values-grid">
                <div class="value-card">
                    <h3>🎯 Reliability</h3>
                    <p>We show up on time, every time. When you call Matria, you know you can count on us.</p>
                </div>
                <div class="value-card">
                    <h3>💼 Professionalism</h3>
                    <p>Our team is trained, licensed, and committed to delivering work that exceeds expectations.</p>
                </div>
                <div class="value-card">
                    <h3>🤝 Integrity</h3>
                    <p>We're transparent about pricing, honest about scope of work, and stand behind our guarantees.</p>
                </div>
                <div class="value-card">
                    <h3>👥 Customer Focus</h3>
                    <p>Your satisfaction is our priority. We listen to your needs and deliver solutions that work.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="why-choose-section">
        <div class="container">
            <h2 class="text-center mb-4">Why Choose Matria?</h2>
            <div class="why-grid">
                <div class="why-item">
                    <span class="why-icon">⚡</span>
                    <h3>Fast Response Times</h3>
                    <p>Available 24/7 for emergencies with same-day service in most cases across Pretoria and Johannesburg.</p>
                </div>
                <div class="why-item">
                    <span class="why-icon">🔒</span>
                    <h3>Fully Licensed & Insured</h3>
                    <p>Our plumbers and electricians are SABS-compliant and fully insured for your peace of mind.</p>
                </div>
                <div class="why-item">
                    <span class="why-icon">💰</span>
                    <h3>Fair & Transparent Pricing</h3>
                    <p>No hidden charges. We provide detailed quotes upfront so you know exactly what to expect.</p>
                </div>
                <div class="why-item">
                    <span class="why-icon">✓</span>
                    <h3>Guarantee Backed</h3>
                    <p>All work is guaranteed for 12 months. We stand behind our workmanship completely.</p>
                </div>
                <div class="why-item">
                    <span class="why-icon">📍</span>
                    <h3>Local Service</h3>
                    <p>We know Pretoria and Johannesburg intimately and serve both residential and commercial clients.</p>
                </div>
                <div class="why-item">
                    <span class="why-icon">🌟</span>
                    <h3>Trusted Locally</h3>
                    <p>Hundreds of satisfied customers across the region have trusted us with their plumbing and electrical needs.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="team-section">
        <div class="container">
            <h2 class="text-center mb-4">Our Commitment</h2>
            <div class="commitment-card">
                <p>At Matria, we believe that providing excellent service means more than just fixing the immediate problem. We take time to explain what went wrong, discuss preventative measures, and ensure you understand the work we've done. Our goal is to build lasting relationships with our clients based on trust and quality workmanship.</p>
                <p>Whether you're facing an emergency burst pipe at 2 AM or planning a complete bathroom renovation, Matria is your reliable partner for all plumbing and electrical needs in Pretoria and Johannesburg.</p>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container cta-content">
            <h2>Experience the Matria Difference</h2>
            <p>Contact us today for professional plumbing and electrical service</p>
            <div class="cta-buttons">
                <a href="/contact/" class="btn btn-primary btn-large">Get in Touch</a>
                <a href="tel:+27737616835" class="btn btn-secondary btn-large">Call: +27 73 761 6835</a>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .page-hero {
        background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 100%);
        color: white;
        padding: 60px 20px;
        text-align: center;
    }

    .page-hero h1 {
        color: white;
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .page-hero p {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.95);
    }

    .about-section {
        padding: 80px 20px;
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .about-content h2 {
        margin-bottom: 1.5rem;
    }

    .about-content p {
        color: #666;
        margin-bottom: 1.5rem;
        line-height: 1.8;
    }

    .about-image img {
        width: 100%;
        border-radius: 12px;
        box-shadow: var(--shadow-lg);
    }

    .values-section {
        padding: 80px 20px;
        background-color: var(--bg-light);
    }

    .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
        margin-top: 3rem;
    }

    .value-card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: var(--shadow);
        text-align: center;
    }

    .value-card h3 {
        color: var(--primary-green);
        margin-bottom: 1rem;
    }

    .why-choose-section {
        padding: 80px 20px;
    }

    .why-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 40px;
        margin-top: 3rem;
    }

    .why-item {
        text-align: center;
    }

    .why-icon {
        font-size: 3rem;
        display: block;
        margin-bottom: 1rem;
    }

    .why-item h3 {
        color: var(--primary-green);
        margin-bottom: 1rem;
    }

    .why-item p {
        color: #666;
    }

    .team-section {
        padding: 60px 20px;
    }

    .commitment-card {
        background: var(--bg-light);
        padding: 40px;
        border-radius: 12px;
        border-left: 4px solid var(--primary-green);
    }

    .commitment-card p {
        color: #666;
        line-height: 1.8;
        margin-bottom: 1.5rem;
        font-size: 1.05rem;
    }

    .commitment-card p:last-child {
        margin-bottom: 0;
    }

    .cta-section {
        background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 100%);
        color: white;
        padding: 60px 20px;
    }

    .cta-content {
        text-align: center;
    }

    .cta-content h2 {
        color: white;
        margin-bottom: 1rem;
    }

    .cta-content p {
        color: rgba(255, 255, 255, 0.95);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    .mb-4 {
        margin-bottom: 2rem;
    }

    @media (max-width: 768px) {
        .page-hero h1 {
            font-size: 2rem;
        }

        .about-grid {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .why-grid {
            grid-template-columns: 1fr;
        }

        .cta-buttons {
            flex-direction: column;
        }
    }
</style>
